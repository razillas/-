local function animateStickman(stickman, leftLeg, rightLeg, leftArm, rightArm)
    local running = true
    
    task.spawn(function()
        while running do
            TweenService:Create(leftLeg, TweenInfo.new(0.2), {Rotation = -40}):Play()
            TweenService:Create(rightLeg, TweenInfo.new(0.2), {Rotation = 40}):Play()
            TweenService:Create(leftArm, TweenInfo.new(0.2), {Rotation = -50}):Play()
            TweenService:Create(rightArm, TweenInfo.new(0.2), {Rotation = 50}):Play()
            task.wait(0.2)
            TweenService:Create(leftLeg, TweenInfo.new(0.2), {Rotation = 40}):Play()
            TweenService:Create(rightLeg, TweenInfo.new(0.2), {Rotation = -40}):Play()
            TweenService:Create(leftArm, TweenInfo.new(0.2), {Rotation = 50}):Play()
            TweenService:Create(rightArm, TweenInfo.new(0.2), {Rotation = -50}):Play()
