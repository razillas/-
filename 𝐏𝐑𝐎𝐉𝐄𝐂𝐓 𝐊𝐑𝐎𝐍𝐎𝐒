                    isHolding = false jitterOn = false jitterPhase = false
                end
            end)
        end)
        local hitboxTimer = 0
        hitboxConn = run.PreSimulation:Connect(function(dt)
            pcall(function()
                if not ballManipEnabled then return end
                hitboxTimer = hitboxTimer + dt
                if hitboxTimer >= (1 / 30) then hitboxTimer = 0 updateHitboxes() end
            end)
        end)
        local jitterTimer = 0
        renderConn = run.RenderStepped:Connect(function(dt)
            pcall(function()
                if not ballManipEnabled then return end
                local char = plr.Character
                if not char then return end
                if jitterOn and ballIsNearby then
                    jitterTimer = jitterTimer + dt
                    if jitterTimer >= 0.055 then jitterTimer = 0 jitterPhase = not jitterPhase end
                else
                    jitterPhase = false jitterTimer = 0
                end
                local hrp = char:FindFirstChild("HumanoidRootPart")
                local ballAirborne = nearestBall and nearestBall.Parent and nearestBall.AssemblyLinearVelocity.Magnitude > 2
                isPulling = ballAirborne and hrp and (nearestBall.Position - hrp.Position).Magnitude <= BALL_RADIUS or false
                disableArmCollision()
                applyHorizPull(char, dt)
                manipulateBall(char, dt)
                tryHeadBounce(char)
                tryHeadBoost(char)
            end)
        end)
        local function applyHipHeight(char)
            pcall(function()
                local hum = char and char:FindFirstChildOfClass("Humanoid")
                if hum then hum.HipHeight = HIP_HEIGHT end
            end)
        end
        local function onCharacter(char)
            pcall(function()
                char:WaitForChild("HumanoidRootPart")
                char:WaitForChild("Humanoid")
                for hrp in pairs(activeHitboxes) do originalSizes[hrp] = nil activeHitboxes[hrp] = nil end
                isOnCooldown = false isJumpCooldown = false isHeadBounceCooldown = false isHolding = false isPulling = false jitterOn = false jitterPhase = false ballIsNearby = false nearestBall = nil cachedBalls = {}
                applyHipHeight(char)
                rebuildArmCache(char)
                task.wait(0.5)
                disableArmCollision()
            end)
        end
        charConn = plr.CharacterAdded:Connect(onCharacter)
        if plr.Character then task.spawn(function() onCharacter(plr.Character) end) end
        table.insert(ballManipConnections, hitboxConn)
        table.insert(ballManipConnections, charConn)
        table.insert(ballManipConnections, renderConn)
        table.insert(ballManipConnections, pullConn)
        table.insert(ballManipConnections, pullEndConn)
        table.insert(ballManipConnections, jumpConn)
    end)
end

local function disableBallManipulation()
    pcall(function()
        ballManipEnabled = false
        for _, conn in ipairs(ballManipConnections) do
            if conn and typeof(conn) == "RBXScriptConnection" then conn:Disconnect() end
        end
        ballManipConnections = {}
        task.wait(0.1)
    end)
end

